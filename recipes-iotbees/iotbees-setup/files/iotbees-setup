#!/bin/sh
# IoT Bees - terminal onboarding wizard (Step 6)
# Configures the gateway: which device to read, and where to push the data.
# Writes /etc/iotbees/agent.conf and restarts the agent service.
#
# Usage:  sudo iotbees-setup

set -e
CONF=/etc/iotbees/agent.conf
CONF_DIR=$(dirname "$CONF")

# Load current values as defaults if a config already exists.
get() { grep -E "^$1[[:space:]]*=" "$CONF" 2>/dev/null | head -1 | cut -d= -f2- | sed 's/^[[:space:]]*//'; }

DEV=$(get device_id);            : "${DEV:=gateway-001}"
MB_HOST=$(get modbus_host);      : "${MB_HOST:=127.0.0.1}"
MB_PORT=$(get modbus_port);      : "${MB_PORT:=502}"
MB_REG=$(get modbus_reg);        : "${MB_REG:=0}"
BROKER=$(get mqtt_broker);       : "${BROKER:=tcp://localhost:1883}"
MQ_USER=$(get mqtt_username);    : "${MQ_USER:=}"
MQ_TOKEN=$(get mqtt_token);      : "${MQ_TOKEN:=}"
T_DATA=$(get mqtt_topic_data);   : "${T_DATA:=iotbees/data}"
T_HEAL=$(get mqtt_topic_health); : "${T_HEAL:=iotbees/health}"
INTERVAL=$(get interval_sec);    : "${INTERVAL:=5}"

ask() { # ask "Prompt" "default" -> echoes answer
  printf "%s [%s]: " "$1" "$2" > /dev/tty
  read ans < /dev/tty
  [ -z "$ans" ] && ans="$2"
  echo "$ans"
}

echo "=================================="
echo "   IoT Bees - gateway setup"
echo "=================================="
echo "Press Enter to keep the [default]."
echo
echo "-- This gateway --"
DEV=$(ask "Device ID" "$DEV")
echo
echo "-- Device to read FROM (Modbus TCP) --"
MB_HOST=$(ask "Modbus host/IP" "$MB_HOST")
MB_PORT=$(ask "Modbus port" "$MB_PORT")
MB_REG=$(ask "Register to read" "$MB_REG")
echo
echo "-- Where to push data TO (your cloud MQTT broker) --"
BROKER=$(ask "MQTT broker URL" "$BROKER")
MQ_USER=$(ask "MQTT username (blank = none)" "$MQ_USER")
MQ_TOKEN=$(ask "MQTT token/password (blank = none)" "$MQ_TOKEN")
T_DATA=$(ask "Data topic" "$T_DATA")
T_HEAL=$(ask "Health topic" "$T_HEAL")
INTERVAL=$(ask "Publish interval (sec)" "$INTERVAL")

mkdir -p "$CONF_DIR"
cat > "$CONF" <<EOF
# IoT Bees agent configuration - generated by iotbees-setup
device_id = $DEV

# Modbus TCP source
modbus_host  = $MB_HOST
modbus_port  = $MB_PORT
modbus_reg   = $MB_REG
modbus_count = 1

# MQTT output (your cloud broker)
mqtt_broker       = $BROKER
mqtt_client_id    = $DEV
mqtt_username     = $MQ_USER
mqtt_token        = $MQ_TOKEN
mqtt_topic_data   = $T_DATA
mqtt_topic_health = $T_HEAL

interval_sec = $INTERVAL
EOF

echo
echo "Saved $CONF"
if command -v systemctl >/dev/null 2>&1; then
  systemctl restart iotbees-agent 2>/dev/null && echo "Restarted iotbees-agent." \
    || echo "Could not restart iotbees-agent (start it with: systemctl start iotbees-agent)."
fi
echo "Setup complete. The gateway is now configured to push to: $BROKER"
